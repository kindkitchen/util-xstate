{
    "tasks": {
        "plop": "deno -A npm:plop --plopfile src/lib/cli/plop.config.ts",
        "test": "deno test --doc"
    },
    "imports": {
        "@std/expect": "jsr:@std/expect@^1.0.19",
        "effect": "npm:effect@^3.21.2",
        "plop": "npm:plop@^4.0.5",
        "xstate": "npm:xstate@^5.31.1"
    },
    "fmt": {
        "indentWidth": 4,
        "quoteProps": "consistent"
    },
    "nodeModulesDir": "auto",
    "compilerOptions": {
        "exactOptionalPropertyTypes": true
    },
    "unstable": ["fmt-component"],
    "version": "0.1.0"
}
